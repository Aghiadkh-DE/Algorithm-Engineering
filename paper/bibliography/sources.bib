@article{10.1007/s11042-014-2269-7,
  author = {Chen, Xin and Gao, Yuefang and Huang, Zhonghong},
  title = {CUDA-accelerated fast Sauvola's method on Kepler architecture},
  year = {2015},
  issue_date = {December  2015},
  publisher = {Kluwer Academic Publishers},
  address = {USA},
  volume = {74},
  number = {24},
  issn = {1380-7501},
  url = {https://doi.org/10.1007/s11042-014-2269-7},
  doi = {10.1007/s11042-014-2269-7},
  abstract = {Sauvola's method is one of the top binarization methods for degraded document images. High computational complexity, however, restricts it to non-time-sensitive applications. In this paper, we present a parallel implementation of Sauvola's method with integral image optimization, called fast Sauvola's method, on Nvidia Kepler architecture GPUs using CUDA 5.0. Our implementation is evaluated on a GTX 650 graphic card (384 cores) and exhibits an average speedup of about 38 compared to a sequential implementation on a fast CPU, and computational complex of our implementation is constant for any size of local windows.},
  journal = {Multimedia Tools Appl.},
  month = dec,
  pages = {11809–11820},
  numpages = {12},
  keywords = {CUDA, GPGPU, Integral image, Sauvola's method}
}

